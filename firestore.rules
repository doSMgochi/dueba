rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /users/{characterName} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if signedIn() &&
        request.resource.data.uid == request.auth.uid &&
        characterName == request.resource.data.characterName &&
        request.resource.data.loginId is string &&
        request.resource.data.nickname is string &&
        request.resource.data.characterName is string &&
        request.resource.data.role == "user";
      allow update, delete: if false;
    }

    match /shop/{itemId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /traits/{traitId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /roulette-items/{itemId} {
      allow read, create, delete: if signedIn();
      allow update: if false;
    }

    match /roulette-logs/{logId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.characterName is string &&
        request.resource.data.rewardName is string &&
        request.resource.data.rewardDescription is string;
      allow update, delete: if false;
    }

    match /announcements/{announcementId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.targetUid == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /parcels/{parcelId} {
      allow read: if signedIn() &&
        (
          resource.data.senderUid == request.auth.uid ||
          resource.data.receiverUid == request.auth.uid
        );
      allow create, update, delete: if false;
    }

    match /live-matches/{matchId} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }
  }
}
