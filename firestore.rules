rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        request.auth.token.role in ["admin", "gm", "moderator"];
    }

    match /users/{characterName} {
      allow read: if signedIn() &&
        (
          characterName == request.auth.uid ||
          resource.data.uid == request.auth.uid ||
          isAdmin()
        );

      allow create: if signedIn() &&
        request.resource.data.uid == request.auth.uid &&
        characterName == request.resource.data.characterName &&
        request.resource.data.loginId is string &&
        request.resource.data.nickname is string &&
        request.resource.data.characterName is string &&
        request.resource.data.role == "user";

      allow update: if false;
      allow delete: if false;
    }

    match /shop/{itemId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /traits/{traitId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /roulette-items/{itemId} {
      allow read, create, delete: if signedIn();
      allow update: if false;
    }

    match /roulette-logs/{logId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.characterName is string &&
        request.resource.data.rewardName is string &&
        request.resource.data.rewardDescription is string;
      allow update, delete: if false;
    }

    match /live-matches/{matchId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn();
    }
  }
}
