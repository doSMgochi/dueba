rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /users/{characterName} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.resource.data.uid == request.auth.uid &&
        characterName == request.resource.data.characterName &&
        request.resource.data.loginId is string &&
        request.resource.data.email is string &&
        request.resource.data.nickname is string &&
        request.resource.data.characterName is string &&
        request.resource.data.friendCode is string &&
        request.resource.data.factionName is string &&
        request.resource.data.role == "user";
      allow update: if signedIn() &&
        resource.data.uid == request.auth.uid &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "dismissedAnnouncementIds",
          "updatedAt",
          "profileSealImage",
          "profileDecorations",
          "extraNicknames",
          "nickname",
          "friendCode",
          "factionName",
          "activeYachtRoomId",
          "activeYachtRole",
          "activeYachtUpdatedAt",
          "activeSessionId",
          "activeSessionUpdatedAt"
        ]);
      allow delete: if false;
    }

    match /shop/{itemId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /item-db/{itemId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /traits/{traitId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /roulette-items/{itemId} {
      allow read, delete: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if signedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.name is string;
      allow update: if false;
    }

    match /roulette-logs/{logId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.characterName is string &&
        request.resource.data.rewardName is string &&
        request.resource.data.rewardDescription is string;
      allow update, delete: if false;
    }

    match /announcements/{announcementId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /notice-logs/{noticeId} {
      allow read, write: if false;
    }

    match /operate-logs/{logId} {
      allow read, write: if false;
    }

    match /match-results/{resultId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /todos/{todoId} {
      allow read: if signedIn();
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if signedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.characterName is string &&
        request.resource.data.text is string;
      allow update: if false;
    }

    match /report-logs/{reportId} {
      allow create: if signedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.characterName is string &&
        request.resource.data.title is string &&
        request.resource.data.body is string &&
        (
          !("screenshotUrls" in request.resource.data) ||
          request.resource.data.screenshotUrls is list
        ) &&
        (
          !("screenshotUrl" in request.resource.data) ||
          request.resource.data.screenshotUrl is string
        );
      allow read, update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.targetUid == request.auth.uid;
      allow update: if signedIn() &&
        resource.data.targetUid == request.auth.uid &&
        request.resource.data.targetUid == resource.data.targetUid &&
        request.resource.data.targetCharacterName == resource.data.targetCharacterName &&
        request.resource.data.type == resource.data.type &&
        request.resource.data.message == resource.data.message &&
        request.resource.data.payload == resource.data.payload &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.isRead == true;
      allow create, delete: if false;
    }

    match /parcels/{parcelId} {
      allow read: if signedIn() &&
        (
          resource.data.senderUid == request.auth.uid ||
          resource.data.receiverUid == request.auth.uid
        );
      allow create, update, delete: if false;
    }

    match /live-matches/{matchId} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }

    match /yacht-rooms/{roomId} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }
  }
}
